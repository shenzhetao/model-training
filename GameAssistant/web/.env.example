# GameAssistant Backend Environment Variables
# Copy this file to .env and configure for your environment
#
# Usage:
#   1. cp .env.example .env
#   2. Edit .env with your values
#   3. For Docker: values are injected via docker-compose.yml

# Application
APP_NAME=GameAssistant API
APP_VERSION=0.1.0
DEBUG=false

# Database (MySQL via Docker)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=gameassistant
MYSQL_USER=gameassistant
MYSQL_PASSWORD=gameassistant
MYSQL_PORT=3306

# Backend
DB_URL=mysql+aiomysql://gameassistant:gameassistant@mysql:3306/gameassistant
BACKEND_PORT=8000

# JWT Authentication
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage (absolute paths recommended for local dev)
UPLOAD_DIR=./uploads
TEMPLATE_DIR=./templates
MODEL_DIR=./models
MAX_UPLOAD_SIZE=2147483648

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Frontend (used by docker-compose)
FRONTEND_PORT=3000
